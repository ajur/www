---
import githubLogoRaw from "./assets/GitHub_Lockup_Black.svg?raw";
import ldjamLogoRaw from "./assets/LudumDare-Logo-Wide.svg?raw";
import itchioLogoRaw from "./assets/itchio-logo-black.svg?raw";
import itchioTextlessLogoRaw from "./assets/itchio-logo-textless-black.svg?raw";
import webLogoRaw from "./assets/web-svgrepo-com.svg?raw";

interface Props {
  url: string;
}

const { url } = Astro.props;
const parsed = new URL(url);
const host = parsed.hostname;
const path = parsed.pathname;

let svg = webLogoRaw;
let alt = host;
let label = "";

if (host === "github.com") {
  svg = githubLogoRaw;
  alt = "GitHub";
} else if (host === "ldjam.com") {
  svg = ldjamLogoRaw;
  alt = "Ludum Dare";
} else if (host.endsWith(".itch.io")) {
  svg = itchioLogoRaw;
  alt = "itch.io";
} else if (host === "itch.io" && path.startsWith("/jam/")) {
  svg = itchioTextlessLogoRaw;
  alt = "itch.io jam";
  label = path.split("/")[2]?.replace(/-/g, " ") ?? "";
} else {
  label = host;
}
---

<a class="link-badge" href={url} target="_blank" rel="noopener noreferrer" title={label ? `${alt} - ${label}` : alt} aria-label={label ? `${alt} - ${label}` : alt}>
  <Fragment set:html={svg} />
  {label && <span class="badge-label">{label}</span>}
</a>

<style>
  .link-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-5) var(--s-2);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius, var(--s-4));
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .link-badge:hover,
  .link-badge:focus-visible {
    border-color: var(--color-accent);
  }

  .link-badge :global(svg) {
    height: 1em;
    width: auto;
  }

  .badge-label {
    font-family: var(--font-display);
    font-weight: bold;
  }
</style>
