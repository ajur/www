---
const { animate = false, glitch = false } = Astro.props;
---

<svg
  data-animate={animate ? true : undefined}
  data-glitch={glitch ? true : undefined}
  width="44.953465"
  height="150.24409"
  clip-rule="evenodd"
  stroke-linecap="round"
  stroke-linejoin="round"
  version="1.1"
  viewBox="0 0 44.953465 150.24409"
  xml:space="preserve"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <defs id="defs1"></defs>
  <path
    d="M 6.9596848,76.243172 C 17.58014,46.578295 28.470893,20.04295 38.651058,1.3326909 34.843739,23.131899 27.401292,63.537807 24.167809,89.849512 23.230598,66.280337 19.174735,61.800653 1.3329092,55.712529 9.2983431,54.493826 39.071187,55.280458 43.620142,55.825608 40.976687,85.57054 33.329019,118.16544 25.034909,148.91078"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="4.343"
    id="path1"
    style="stroke-width:2.66667;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:none;stroke-dashoffset:0"
  ></path>
</svg>

<style>
  svg {
    display: block;
    width: auto;
    height: 12rem;
    color: var(--color-ink);
  }

  svg[data-animate] {
    animation: logo-neon 5s ease-in-out infinite;
  }

  @keyframes logo-neon {
    0%,
    100% {
      filter: drop-shadow(0 0 0 var(--color-ink));
    }
    50% {
      filter: drop-shadow(0 0 0.2rem var(--color-ink));
    }
  }

  svg[data-glitch] {
    animation: logo-glitch 3s steps(1) infinite;
  }

  @keyframes logo-glitch {
    /* --- clean --- */
    0%, 100% {
      transform: none;
      filter: none;
      clip-path: none;
      opacity: 1;
    }

    /* --- 1: short chromatic shift --- */
    8% {
      transform: translate(-2px, 0);
      filter: drop-shadow(-2px 0 0 var(--color-accent-strong))
              drop-shadow(2px 0 0 var(--color-accent-muted));
    }
    10% {
      transform: none;
      filter: none;
    }

    /* --- breathing room --- */

    /* --- 2: shifted + clipped burst --- */
    32% {
      transform: translate(-3px, 1px) skewX(-2deg);
      filter: drop-shadow(-2px 0 0 var(--color-accent-strong))
              drop-shadow(2px 0 0 var(--color-accent-muted));
      clip-path: inset(15% 0 55% 0);
    }
    33% {
      transform: translate(2px, -1px) skewX(1deg);
      filter: drop-shadow(2px 0 0 var(--color-accent-strong))
              drop-shadow(-2px 0 0 var(--color-accent-muted));
      clip-path: inset(50% 0 15% 0);
    }
    35% {
      transform: none;
      filter: none;
      clip-path: none;
    }

    /* --- breathing room --- */

    /* --- 3: big chromatic shift + wide skew → clip → disappear --- */
    62% {
      transform: translate(-4px, 0) skewX(-5deg);
      filter: drop-shadow(-4px 0 0 var(--color-accent-strong))
              drop-shadow(4px 0 0 var(--color-accent-muted));
    }
    63% {
      transform: translate(3px, -2px) skewX(6deg);
      filter: drop-shadow(-5px 0 0 var(--color-accent-strong))
              drop-shadow(5px 0 0 var(--color-accent-muted));
      clip-path: inset(10% 0 60% 0);
    }
    64% {
      transform: translate(-2px, 1px) skewX(-4deg);
      clip-path: inset(40% 0 20% 0);
      filter: drop-shadow(-3px 0 0 var(--color-accent-strong))
              drop-shadow(3px 0 0 var(--color-accent-muted));
    }
    65% {
      opacity: 0;
      clip-path: inset(0);
      transform: none;
      filter: none;
    }

    /* --- gone for a moment --- */
    72% {
      opacity: 0;
      transform: none;
      filter: none;
      clip-path: none;
    }

    /* --- bring back --- */
    73% {
      opacity: 1;
      transform: translate(1px, 0);
      filter: drop-shadow(-2px 0 0 var(--color-accent-strong))
              drop-shadow(2px 0 0 var(--color-accent-muted));
    }
    75% {
      opacity: 1;
      transform: none;
      filter: none;
      clip-path: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    svg {
      animation: none;
      filter: drop-shadow(-2px 0 0 var(--color-accent-strong))
              drop-shadow(2px 0 0 var(--color-accent-muted));
    }
  }
</style>
