---
import PageLayout from "~/layouts/PageLayout.astro";
import ContentTag from "~/components/ContentTag.astro";
import { getTagsContent } from "~/utils";

const collectionNamesMap = {
  articles: "text",
  projects: "code",
  art: "art",
  misc: "misc"
};

const collections = Object.keys(collectionNamesMap) as (keyof typeof collectionNamesMap)[];

const tagsMap = await getTagsContent();
const tagsList = Array.from(tagsMap.keys()).sort((a, b) => a.localeCompare(b));

---
<PageLayout title="Miscellaneous">
  <main class="the-center">
    <header>
      <h1>Tags</h1>
      <p>Listing all available tags.</p>
    </header>

    <ul>
      {tagsList.map((tag) => (
        <li>
          <div class="tag-row">
            <ContentTag tag={tag} />

            
              {collections.map((collection) => {
                const collectionItems = tagsMap.get(tag)?.[collection] || [];
                if (collectionItems.length === 0) return null;

                return (
                  <span class="tag-count">
                    {collectionNamesMap[collection]}: {collectionItems.length}
                  </span>
                );
              })}
            
          </div>
        </li>
      ))}
    </ul>
  </main>
</PageLayout>

<style>
  main {
    padding-inline: var(--s0);
  }

  header {
    text-align: center;
    padding-block: var(--s2);
  }

  header > *:first-child {
    margin-block-start: 0;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    max-inline-size: var(--measure);
  }

  .tag-row {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-block: var(--s-4);
  }

  .tag-count {
    color: var(--color-ink-muted);
  }

  p {
    margin: 0;
    margin-top: var(--s-3);
  }
</style>