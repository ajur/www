---
import { getCollection } from "astro:content";
import PageLayout from "~/layouts/PageLayout.astro";
import GalleryGrid from "~/components/GalleryGrid.astro";

const entries = (await getCollection("art")).sort((a, b) =>
  b.data.created.localeCompare(a.data.created) || b.id.localeCompare(a.id)
);
---

<PageLayout title="Art">
  <main>
    <GalleryGrid entries={entries} />
  </main>
</PageLayout>

<style>
  main {
    padding: var(--s0) 1vw;
  }
</style>
