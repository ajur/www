---
import PageLayout from "~/layouts/PageLayout.astro";
import ContentTag from "~/components/ContentTag.astro";
import { getCollection } from "astro:content";
import { formatDate } from "~/utils";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);

---

<PageLayout title="Text">
  <main class="the-center">
    <header>
      <h1>Text</h1>
      <p>Writing notes and longer essays.</p>
    </header>

    <ul>
      {articles.map((page) => (
        <li>
          <a href={`/articles/${page.id}/`}>
            <h2>{page.data.title}</h2>
          </a>
          <div class="meta">
            <div class="published-date">{formatDate(page.data.published)}</div>
            {page.data.tags.length > 0 && (
              <div class="tags">
                {page.data.tags.map((tag) => <ContentTag tag={tag} />)}
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </main>
</PageLayout>


<style>
main {
  padding-inline: var(--s0);
}

header {
  text-align: center;
  padding-block: var(--s2);
}

header > *:first-child {
  margin-block-start: 0;
}

ul {
  list-style: none;
  padding: 0;
  margin: 0;
  inline-size: 100%;
  max-inline-size: var(--measure);
}

a {
  display: block;
  padding-block-start: var(--s1);
  padding-block-end: var(--s-1);
  border-top: 1px solid var(--color-border);
  text-decoration: none;
  color: inherit;
}

a:hover,
a:focus-visible {
  color: var(--color-accent);
}

h2 {
  font-size: var(--s1);
  margin: 0;
}

p {
  margin: 0;
}

.meta {
  display: flex;
  align-items: baseline;
  gap: var(--s-2);
  padding-block-end: var(--s1);
}

.published-date {
  color: var(--color-ink-muted);
}

.tags {
  margin-inline-start: auto;
  display: flex;
  flex-wrap: wrap;
  gap: var(--s-5);
}
</style>