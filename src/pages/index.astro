---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackgroundAnimator from "../components/BackgroundAnimator.astro";
import Logo from "../components/Logo.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
---

<BaseLayout title="Home">
  <BackgroundAnimator />
  <main>
    <Logo animate />

    <nav aria-label="Primary">
      <ul>
        <li><a href="/articles/">Text</a></li>
        <li><a href="/projects/">Code</a></li>
        <li><a href="/misc/">Misc</a></li>
        <li><a href="/about/" data-astro-prefetch>Self</a></li>
      </ul>

      <div class="theme-switcher-wrap" aria-label="Theme">
        <ThemeSwitcher placement="below" />
      </div>
    </nav>
  </main>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    overflow: hidden;
  }
  :global(body) {
    overscroll-behavior: none;
  }

  main {
    height: 100svh;
    display: flex;
    padding: 1rem;
    text-align: center;
    flex-flow: column wrap;
    justify-content: center;
    align-items: center;
    align-content: center;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  nav {
    padding: 1rem;
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-4);
  }

  nav a {
    font-family: var(--font-mono);
    font-size: var(--s1);
    text-transform: lowercase;
    text-decoration: none;
    letter-spacing: 0.1em;
    filter: drop-shadow(-0.1em -0.1em 0.3rem var(--color-bg))
      drop-shadow(0.1em 0.1em 0.3rem var(--color-bg))
      drop-shadow(0.1em -0.1em 0.3rem var(--color-bg))
      drop-shadow(-0.1em 0.1em 0.3rem var(--color-bg));
  }
  nav a:hover,
  nav a:focus-visible {
    color: var(--color-accent-strong);
  }

  .theme-switcher-wrap {
    position: fixed;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 20;
    max-inline-size: none;
    filter: drop-shadow(-0.1em -0.1em 0.3rem var(--color-bg))
      drop-shadow(0.1em 0.1em 0.3rem var(--color-bg))
      drop-shadow(0.1em -0.1em 0.3rem var(--color-bg))
      drop-shadow(-0.1em 0.1em 0.3rem var(--color-bg));
  }
</style>
